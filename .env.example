# Database (external PostgreSQL on infra — required for migrate/api/seed)
# On the server use the real host IP/hostname, not localhost / host.docker.internal
DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/ebraz-clinic-db?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long

# API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:4000

# Seed — dev users locally; production Docker seed profile sets this to false
SEED_DEV_USERS=true

# SMS (sms.ir) — omit SMSIR_API_KEY to log messages instead of sending
SMSIR_API_KEY=
SMSIR_LINE_NUMBER=9982005424
SMS_ADMIN_PHONE=

# Notifications — real-time is placeholder until WebSocket/Pusher is wired
NOTIFICATIONS_REALTIME_ENABLED=false

# File uploads — stored under packages/api/public/uploads (served at /uploads/...)
# UPLOAD_ROOT=

# JSON backups — stored under packages/api/public/backups (served at /backups/...)
# BACKUP_ROOT=

# Legacy MySQL (Phase 17 data migration only)
# MYSQL_DATABASE_URL=mysql://root:password@localhost:3306/ebraz_clinic
# Run: pnpm db:migrate:mysql:dry  then  pnpm db:migrate:mysql
