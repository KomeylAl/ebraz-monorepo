{
  "name": "@ebraz/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seed.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "clean": "rimraf dist",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:migrate:mysql": "dotenv -e ../../.env -- tsx src/migrate-from-mysql/cli.ts",
    "db:migrate:mysql:dry": "dotenv -e ../../.env -- tsx src/migrate-from-mysql/cli.ts --dry-run",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^3.0.2",
    "mysql2": "^3.14.2"
  },
  "devDependencies": {
    "@ebraz/eslint-config": "workspace:*",
    "@ebraz/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.32",
    "eslint": "^9.30.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.11.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
