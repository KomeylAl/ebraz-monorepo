    "@ebraz/validation": "workspace:*",
    "next": "^16.0.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@ebraz/eslint-config": "workspace:*",
    "@ebraz/tsconfig": "workspace:*",
    "@types/node": "^22.15.32",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.30.1",
    "dotenv-cli": "^8.0.0",
